/external_sd    vfat    /dev/block/mmcblk1p1    /dev/block/mmcblk1  flags=display="MicroSD";storage;wipeui;removable
/usb_otg        vfat    /dev/block/sda1         /dev/block/sda      flags=display="USB OTG";storage;wipeui;removable
/boot           emmc    /dev/block/by-name/boot             flags=display="Boot";backup=1;flashimg=1
/vendor_boot    emmc    /dev/block/by-name/vendor_boot      flags=display="Vendor Boot";backup=1;flashimg=1
/vbmeta         emmc    /dev/block/by-name/vbmeta           flags=display="VBMeta";backup=1;flashimg=1
/data           f2fs    /dev/block/by-name/userdata         flags=display="Data"
